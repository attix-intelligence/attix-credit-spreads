# ═══════════════════════════════════════════════════════════════════════════
# .env.exp1220 — Environment variables for EXP-1220 Paper Trading
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env (or .env.exp1220) and fill in actual credentials.
# NEVER commit the real file to git.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Alpaca Paper Trading (REQUIRED) ────────────────────────────────────────
# Account: PA3YFVQCXTD6
# Create/view keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_api_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Experiment metadata ────────────────────────────────────────────────────
EXPERIMENT_ID=EXP-1220
EXPERIMENT_NAME=EXP-1220 Paper Trading 1.5x Static
PAPER_ACCOUNT=PA3YFVQCXTD6

# ─── Telegram alerts (OPTIONAL but recommended) ─────────────────────────────
# Get bot token from @BotFather on Telegram.
# Get chat ID: message your bot, then visit
#   https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Data sources (OPTIONAL) ────────────────────────────────────────────────
# Polygon is only used for historical backfills, not live trading.
# The scanner uses Yahoo Finance for VIX/SPY (free, no key needed).
POLYGON_API_KEY=

# ─── Notes ──────────────────────────────────────────────────────────────────
# The scanner only needs ALPACA_API_KEY + ALPACA_SECRET_KEY to trade.
# Everything else is optional. Test with:
#   source .env && python3 scripts/run_exp1220.py --smoke-test
