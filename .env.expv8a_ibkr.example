# EXP-V8A-IBKR — 10th experiment, IBKR paper via executor service, 3× sizing
# Copy to .env.expv8a_ibkr and fill in the real secrets (DO NOT COMMIT FILLED VERSION)

# --- Executor / IBKR routing (NEW — what makes this V8A-IBKR distinct) ---
SINK_TYPE=executor
EXECUTOR_BASE_URL=https://executor-production.up.railway.app    # Railway public URL (TBD until deploy)
EXECUTOR_API_KEY=usr_REPLACE_WITH_REAL_KEY                       # generated by executor's /auth/register
EXECUTOR_ACCOUNT_ID=ibkr_tafintech-p11-paper                     # confirmed via /v1/gateways/accounts
EXECUTOR_ACCOUNT_TYPE=paper
EXECUTOR_TIMEOUT_S=15.0

# --- Signal-side data (UNCHANGED — same Polygon access as Alpaca V8A) ---
POLYGON_API_KEY=REPLACE_WITH_REAL_KEY
POLYGON_OPTIONS_API_KEY=REPLACE_WITH_REAL_KEY                    # Polygon Options Starter — required for IV chains

# --- Alpaca (UNUSED but required by legacy code paths; harmless placeholders) ---
ALPACA_API_KEY=unused
ALPACA_API_SECRET=unused
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# --- Alerts (distinct chat from EXP-V8A — sets the experiment_id prefix automatically) ---
TELEGRAM_BOT_TOKEN=REPLACE_WITH_REAL_TOKEN
TELEGRAM_CHAT_ID=REPLACE_WITH_REAL_CHAT_ID

# --- Dashboard sync (same as Alpaca worker) ---
DASHBOARD_API_KEY=REPLACE_WITH_REAL_KEY
RAILWAY_SERVICE_ATTIX_DASHBOARD_URL=attix-production.up.railway.app

# --- DB path (already in YAML, but env overrides if set) ---
ATTIX_DB_PATH=data/pilotai_expv8a_ibkr.db

# --- Optional: monitoring/guardrails for week 1 (informational only until PR-M) ---
V8A_IBKR_MAX_AGGREGATE_LOSS_RATIO=3.5
V8A_IBKR_MAX_MARGIN_USED_RATIO=0.85
V8A_IBKR_DAILY_LOSS_HALT_PCT=20
